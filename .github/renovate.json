{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "onboarding": false,
  "enabledManagers": [
    "docker-compose",
    "dockerfile",
    "github-actions",
    "npm",
    "nvm"
  ],
  "useBaseBranchConfig": "merge",
  "commitMessagePrefix": "[RENOVATE]",
  "platform": "github",
  "forkProcessing": "enabled",
  "repositories": ["betagouv/mon-service-securise"],
  "packageRules": [
    {
      "description": "lockFileMaintenance",
      "matchUpdateTypes": [
        "pin",
        "digest",
        "patch",
        "minor",
        "major",
        "lockFileMaintenance"
      ],
      "minimumReleaseAge": "7 days"
    }
  ]
}
