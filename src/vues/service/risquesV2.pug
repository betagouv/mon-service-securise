extends ../parcoursService
include ../fragments/texteTronque

block title
  title Risques de sécurité | MonServiceSécurisé

block titre
  h1 Risques de sécurité

block sous-titre
  h2
    p Réalisez une première étude de vos risques grâce à l'outil d'études des risques usuels proposé ci-dessous par l'ANSSI et/ou recensez les risques identifiés dans le cadre d'une analyse de risque plus approfondie.
    p Ces risques sont créés et caractérisés automatiquement et doivent être revus avant présentation en commission. Découvrez&nbsp;
      dsfr-link(label="comment fonctionne le moteur de risques", href="https://app.crisp.chat/website/83715488-f261-43fe-806b-519f8611e146/helpdesk/articles/fr/1bead123-e8fc-42ef-83c8-21b5ce75807c/", blank, neutral)
      | .

block append scripts
  +donneesPartagees('referentiel-statuts-mesures', referentiel.statutsMesures())
  +donneesPartagees('donnees-referentiel-gravite', referentiel.niveauxGravite())
  +donneesPartagees('donnees-referentiel-vraisemblances', referentiel.niveauxVraisemblance())
  +donneesPartagees('donnees-risques-v1', risquesV1)

block formulaire
  #conteneur-risques-v2
  +composantSvelte('risquesV2.js')
  script(type = 'module', src = '/statique/service/risquesV2.mjs')