extends ../mssConnecte
include ../tiroirs/tiroir.pug

block append styles
  link(href = '/statique/assets/styles/parcoursService.css', rel = 'stylesheet')
  link(href = '/statique/assets/styles/tiroir.css', rel = 'stylesheet')
  link(href = '/statique/assets/styles/modules/selectize.css', rel = 'stylesheet')
  link(href = '/statique/assets/styles/formulaire.css', rel = 'stylesheet')
  link(href = '/statique/assets/styles/homologation/formulaire.css', rel = 'stylesheet')
  link(href = '/statique/assets/styles/homologation/mesures.css', rel = 'stylesheet')

block append scripts
  +composantSvelte('mesure.js')
  +composantSvelte('pagesService.js')
  script(type = 'module', src = '/statique/service/pagesService.mjs')
  +donneesPartagees('etape-active', etapeActive)
  +donneesPartagees('autorisations-service', autorisationsService)
  +donneesPartagees('suggestions-service', {finalisationDescriptionServiceImporte: service.pourraitFaire('finalisationDescriptionServiceImporte')})
  +donneesPartagees('referentiel', {
    indiceCyber: {
      noteMax: referentiel.indiceCyberNoteMax()
    },
    mesures: {
      categories: referentiel.categoriesMesures(),
      priorites: referentiel.prioritesMesures(),
      statuts: referentiel.statutsMesures(),
      retoursUtilisateur: referentiel.retoursUtilisateurMesure()
    },
    risques: {
      categories: referentiel.detailCategoriesRisque(),
      gravites: referentiel.niveauxGravite(),
      vraisemblances: referentiel.niveauxVraisemblance(),
      descriptions: referentiel.risques(),
      matrice: referentiel.matriceNiveauxRisques(),
      niveaux: referentiel.niveauxRisque()
    },
    dossiers: {
      statutsHomologation: referentiel.statutsHomologation(),
      etapesParcoursHomologation: referentiel.etapesParcoursHomologation(autorisationsService.peutHomologuer),
      statutsAvisDossierHomologation: referentiel.statutsAvisDossierHomologation(),
      echeancesRenouvellement:  referentiel.echeancesRenouvellement()
    }
  })
  +donneesPartagees('feature-flags', { avecRisquesV2: featureFlags.avecRisquesV2 })
  +donneesPartagees('preferences-utilisateur', { afficheExplicationRisquesV2 })
  +donneesPartagees('nonce-commentaires', nonce)

block main
  #pages-service(data-id-service=service.id)

  +tiroir
    include ../tiroirs/tiroirTelechargement
    include ../tiroirs/tiroirMesure
    include ../tiroirs/tiroirExportMesures
    include ../tiroirs/tiroirSuppressionDossierCourant