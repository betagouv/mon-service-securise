extends ../formulaireEtapier

block title
  title Homologuer - Récapitulatif | MonServiceSécurisé

block contenu-etape
  -
    const LABEL_BOUTON = 'Enregistrer la décision';
    const dossierCourant = service.dossierCourant();
    const dureeValidite = dossierCourant.descriptionDureeValidite();
    const dateHomologation = dossierCourant.descriptionDateHomologation();

  section
    if dossierCourant.estRefuse()
      p.
        La décision d'homologation de sécurité a été prise le #[b= dateHomologation].
        #[br]
        L'homologation de sécurité a été #[b refusée].#[br]
        #[br]
        En cliquant sur « #{LABEL_BOUTON} », vous confirmez l’exactitude des
        informations renseignées conformément au document « Décision d’homologation de sécurité ».
    else
      p.
        La décision d'homologation de sécurité a été prise le
        #[b= dateHomologation] pour une durée de #[b= dureeValidite]. #[br]
        #[br]
        En cliquant sur « #{LABEL_BOUTON} », vous confirmez l’exactitude des
        informations renseignées conformément au document « Décision d’homologation de sécurité ».

  script(type = "module", src = "/statique/service/homologation/etapes/recapitulatif.js")

block contenu-demarche-homologation

block bouton-etape
  button(type = 'submit', data-id-homologation = service.id, data-id-etape = idEtape).bouton#suivant= LABEL_BOUTON
