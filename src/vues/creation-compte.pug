extends ./mss
include ./fragments/header

block append styles
    link(href = '/statique/assets/styles/creation-compte.css', rel = 'stylesheet')
    link(href = '/statique/assets/styles/formulaire.css', rel = 'stylesheet')

block append scripts
    +composantSvelte('inscription.js')
    +donneesPartagees('configuration-composant-svelte',{estimationNombreServices})
    +donneesPartagees('token',{token})
    +donneesPartagees('informations-professionnelles', { informationsProfessionnelles })
    +donneesPartagees('departements', { departements })
    +donneesPartagees('invite', invite)

block header
    +header(avertissementMaintenance, featureFlags, true, '/', "Retour à l'accueil du site MonServiceSécurisé - République Française", true)

block main
    #conteneur-inscription

    script(type = 'module', src = '/statique/creation-compte.mjs')
