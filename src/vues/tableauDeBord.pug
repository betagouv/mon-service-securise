extends mssConnecte

block append styles
  link(href = '/statique/assets/styles/tiroir.css', rel = 'stylesheet')
  link(href = '/statique/assets/styles/formulaire.css', rel = 'stylesheet')
  link(href = '/statique/assets/styles/modules/selectize.css', rel = 'stylesheet')

block append scripts
  +composantSvelte('tableauDeBord.js')
  +composantSvelte('explicationNouveauReferentiel.js')
  +composantSvelte('explicationUtilisationMFA.js')
  +donneesPartagees('utilisateur-superviseur', {estSuperviseur})
  +donneesPartagees('affiche-explication-nouveau-referentiel', afficheExplicationNouveauReferentiel)
  +donneesPartagees('affiche-explication-utilisation-mfa', afficheExplicationUtilisationMFA)
  script(type = 'module', src = '/statique/tableauDeBord.mjs')

block main
  #tableau-de-bord
  #rapport-televersement
  #explication-nouveau-referentiel
  #explication-utilisation-mfa