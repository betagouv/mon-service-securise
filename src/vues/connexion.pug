extends ./mss
include ./fragments/header

block append styles
    link(href = '/statique/assets/styles/connexion.css', rel = 'stylesheet')
    link(href = '/statique/assets/styles/formulaire.css', rel = 'stylesheet')

block append scripts
    +composantSvelte('connexion.js')
    +donneesPartagees('url-redirection', {urlRedirection})

block header
    +header(avertissementMaintenance, featureFlags, true, '/', "Retour à l'accueil du site MonServiceSécurisé - République Française", true)

block main
    #conteneur-connexion

    script(type = 'module', src = '/statique/connexion.mjs')
