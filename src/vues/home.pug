extends mssDeconnecte
include ./fragments/navigationSiteVitrine
block variables
  - const meta_description = 'Pilotez la sécurité de vos services numériques en équipe et homologuez les rapidement avec MonServiceSécurisé. Découvrez maintenant !'

mixin contenuAvantage(titre, description)
  .contenu-avantage
    h4= titre
    p= description

mixin etape(numero, titre, description, afficheChemin = true)
  .etape
    img.taille-maximale.tres-petite-marge-basse(loading="lazy" src=`/statique/assets/images/home/illustration_etape_${numero}.svg` alt='')
    .numero-etape.tres-petite-marge-basse(class=`numero-${numero}`)
      span= numero
    .contenu-texte-etape
      h4.alignement-gauche= titre
      p.alignement-gauche= description
    if afficheChemin
      img.visible-uniquement-desktop.chemin(src='/statique/assets/images/home/chemin_etape_gauche.svg' alt='')

mixin chiffreCle(chiffre, description)
  .chiffre-cle
    h4.alignement-gauche.centre-tablette.couleur-principale-foncee= chiffre
    p.alignement-gauche.centre-tablette= description

mixin carteCarrousel(numero, titre, description)
  dsfr-tile(
    class="carte-carrousel"
    id=`slide-${numero}`
    title=titre
    markup="h3"
    description=description
    details="Détail (optionnel)"
    action-markup="false"
    href="#"
    size="md"
    vertical-breakpoint="false"
    variations="none"
    markup-level="2"
    has-description
    no-link
  )

mixin carrousel(id, texteBoutonSuivant)
  div(id=id)
    .conteneur-carrousel
      block
    .conteneur-liens-carrousel
      dsfr-button(
        class="precedent"
        label="Précédent"
        kind="tertiary-no-outline"
        size="md"
        icon="arrow-left-s-line"
        icon-place="left"
        markup="button"
        type="button"
        has-icon
      )
      dsfr-button(
        class="suivant"
        label="Suivant"
        kind="tertiary-no-outline"
        size="md"
        icon="arrow-right-s-line"
        icon-place="right"
        markup="button"
        type="button"
        has-icon
      )

mixin carteAvecImage(titre, imageSrc, tag)
  dsfr-card(
    title=titre
    size="md"
    src=imageSrc
    alt=titre
    has-tag
    no-link
  )
    dsfr-tag(slot="tagsgroup" label=tag)

mixin carteRetractable(titre, description, imgSrc)
  .carte-retractable
    p.titre-carte-retractable= titre
    p.description-carte-retractable= description
    img(src=imgSrc, alt=titre)


block append styles
  link(href='/statique/assets/styles/entete.responsive.css', rel='stylesheet')
  link(href='/statique/assets/styles/home.css', rel='stylesheet')
  link(href='/statique/assets/styles/home.tablette.css', rel='stylesheet')
  link(href='/statique/assets/styles/home.desktop.css', rel='stylesheet')

block append scripts
  script(type = 'module', src = '/statique/home.js')

block navigation-site-vitrine
  +navigationSiteVitrine('accueil')

