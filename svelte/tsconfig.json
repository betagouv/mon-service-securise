{
  "extends": "@tsconfig/svelte/tsconfig.json",
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "allowJs": true,
    "checkJs": true,
    "isolatedModules": true,
    "strict": true,
    "ignoreDeprecations": "5.0",
    "types": ["vitest/globals"]
  },
  "include": [
    "types.d.ts",
    "vite.config.mts",
    "lib/**/*.d.ts",
    "lib/**/*.ts",
    "lib/**/*.js",
    "lib/**/*.svelte",
    "test/**/*.ts",
    ".eslintrc.cjs"
  ]
}
